pageextension 50103 "Item List Extension" extends "Item List"
{
    actions
    {
        addlast(processing)
        {
            action(CreateItemJournalLine)
            {
                Caption = 'Create Item Journal Line';
                ApplicationArea = All;
                Image = Journal;
                ToolTip = 'Create item journal adjustment lines for the selected item(s) with optional lot tracking.';

                trigger OnAction()
                var
                    SelectedItem: Record Item;
                    ItemJournalInput: Page "Item Journal Input";
                    TempEntry: Record "Item Journal Batch Entry" temporary;
                    MakeOrdersMgt: Codeunit "Make Orders Mgt";
                    LineCount: Integer;
                begin
                    CurrPage.SetSelectionFilter(SelectedItem);
                    if SelectedItem.FindSet() then
                        repeat
                            ItemJournalInput.AddItem(SelectedItem."No.");
                        until SelectedItem.Next() = 0;
                    if ItemJournalInput.RunModal() = Action::OK then begin
                        ItemJournalInput.GetEntries(TempEntry);
                        if TempEntry.FindSet() then
                            repeat
                                MakeOrdersMgt.CreateItemJournalLine(
                                    TempEntry."Item No.", TempEntry."Lot No.", TempEntry."Location Code", TempEntry.Quantity);
                                LineCount += 1;
                            until TempEntry.Next() = 0;
                        Message('%1 Item Journal Line(s) created successfully.', LineCount);
                    end;
                end;
            }
        }
        addfirst(Promoted)
        {
            actionref(CreateItemJournalLineRef; CreateItemJournalLine)
            {
            }
        }
    }
}
