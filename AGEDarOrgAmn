reportextension 50104 "AgedAR NA Add Original Amt" extends "Aged Accounts Receivable NA"
{
    dataset
    {
        add(Totals)
        {
            column(OriginalAmount; GetOriginalAmount())
            {
            }
            column(OriginalAmountCaption; OriginalAmountLbl) { }

            column(OriginalAmountLCY; GetOriginalAmountLCY())
            {
            }
            column(OriginalAmountLCYCaption; OriginalAmountLCYLbl) { }
        }
    }

    var
        OriginalAmountLbl: Label 'Original Amount';
        OriginalAmountLCYLbl: Label 'Original Amount (LCY)';

    local procedure GetOriginalAmount(): Decimal
    var
        CustLedgEntry: Record "Cust. Ledger Entry";
        DtldCustLedgEntry: Record "Detailed Cust. Ledg. Entry";
        AppliedCLE: Record "Cust. Ledger Entry";
        TotalOrigAmt: Decimal;
    begin
        if not CustLedgEntry.Get("Cust. Ledger Entry"."Entry No.") then
            exit(0);

        if CustLedgEntry."Document Type" = CustLedgEntry."Document Type"::Invoice then
            exit(CustLedgEntry."Original Amount");

        TotalOrigAmt := 0;
        DtldCustLedgEntry.SetRange("Cust. Ledger Entry No.", CustLedgEntry."Entry No.");
        DtldCustLedgEntry.SetRange("Entry Type", DtldCustLedgEntry."Entry Type"::Application);
        if DtldCustLedgEntry.FindSet() then
            repeat
                if AppliedCLE.Get(DtldCustLedgEntry."Applied Cust. Ledger Entry No.") then
                    if AppliedCLE."Document Type" = AppliedCLE."Document Type"::Invoice then
                        TotalOrigAmt += AppliedCLE."Original Amount";
            until DtldCustLedgEntry.Next() = 0;

        exit(TotalOrigAmt);
    end;

    local procedure GetOriginalAmountLCY(): Decimal
    var
        CustLedgEntry: Record "Cust. Ledger Entry";
        DtldCustLedgEntry: Record "Detailed Cust. Ledg. Entry";
        AppliedCLE: Record "Cust. Ledger Entry";
        TotalOrigAmtLCY: Decimal;
    begin
        if not CustLedgEntry.Get("Cust. Ledger Entry"."Entry No.") then
            exit(0);

        if CustLedgEntry."Document Type" = CustLedgEntry."Document Type"::Invoice then begin
            CustLedgEntry.CalcFields("Original Amt. (LCY)");
            exit(CustLedgEntry."Original Amt. (LCY)");
        end;

        TotalOrigAmtLCY := 0;
        DtldCustLedgEntry.SetRange("Cust. Ledger Entry No.", CustLedgEntry."Entry No.");
        DtldCustLedgEntry.SetRange("Entry Type", DtldCustLedgEntry."Entry Type"::Application);
        if DtldCustLedgEntry.FindSet() then
            repeat
                if AppliedCLE.Get(DtldCustLedgEntry."Applied Cust. Ledger Entry No.") then
                    if AppliedCLE."Document Type" = AppliedCLE."Document Type"::Invoice then begin
                        AppliedCLE.CalcFields("Original Amt. (LCY)");
                        TotalOrigAmtLCY += AppliedCLE."Original Amt. (LCY)";
                    end;
            until DtldCustLedgEntry.Next() = 0;

        exit(TotalOrigAmtLCY);
    end;
}
