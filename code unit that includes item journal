codeunit 50101 "Make Orders Mgt"
{
    procedure CreateOrdersFromBlankets(var BlanketHeader: Record "Purchase Header"; PostingDate: Date)
    var
        OrderCount: Integer;
    begin
        OrderCount := 0;
        if BlanketHeader.FindSet() then
            repeat
                CreatePurchaseOrder(BlanketHeader, PostingDate);
                OrderCount += 1;
            until BlanketHeader.Next() = 0;

        if OrderCount > 0 then
            Message('%1 purchase order(s) created successfully.', OrderCount)
        else
            Message('No blanket purchase orders were processed.');
    end;

    procedure CreateItemJournalLine(ItemNo: Code[20]; LotNo: Code[50]; LocationCode: Code[10]; Qty: Decimal)
    var
        ItemJnlLine: Record "Item Journal Line";
        ItemJnlTemplate: Record "Item Journal Template";
        ItemJnlBatch: Record "Item Journal Batch";
        ReservEntry: Record "Reservation Entry";
        NextLineNo: Integer;
        NextReservEntryNo: Integer;
    begin
        if Qty = 0 then
            Error('Quantity cannot be zero.');

        if not ItemJnlTemplate.Get('ITEM') then
            if not ItemJnlTemplate.FindFirst() then
                Error('No Item Journal Template found.');

        if not ItemJnlBatch.Get(ItemJnlTemplate.Name, 'DEFAULT') then begin
            ItemJnlBatch.Init();
            ItemJnlBatch."Journal Template Name" := ItemJnlTemplate.Name;
            ItemJnlBatch.Name := 'DEFAULT';
            ItemJnlBatch.Description := 'Default Batch';
            ItemJnlBatch.Insert(true);
        end;

        ItemJnlLine.SetRange("Journal Template Name", ItemJnlTemplate.Name);
        ItemJnlLine.SetRange("Journal Batch Name", ItemJnlBatch.Name);
        if ItemJnlLine.FindLast() then
            NextLineNo := ItemJnlLine."Line No." + 10000
        else
            NextLineNo := 10000;

        ItemJnlLine.Init();
        ItemJnlLine."Journal Template Name" := ItemJnlTemplate.Name;
        ItemJnlLine."Journal Batch Name" := ItemJnlBatch.Name;
        ItemJnlLine."Line No." := NextLineNo;
        ItemJnlLine.Validate("Posting Date", Today());
        ItemJnlLine.Validate("Item No.", ItemNo);
        ItemJnlLine.Validate("Location Code", LocationCode);

        if Qty > 0 then begin
            ItemJnlLine."Entry Type" := ItemJnlLine."Entry Type"::"Positive Adjmt.";
            ItemJnlLine.Validate(Quantity, Qty);
        end else begin
            ItemJnlLine."Entry Type" := ItemJnlLine."Entry Type"::"Negative Adjmt.";
            ItemJnlLine.Validate(Quantity, -Qty);
        end;

        ItemJnlLine.Insert(true);

        if LotNo <> '' then begin
            ReservEntry.LockTable();
            ReservEntry.Reset();
            if ReservEntry.FindLast() then
                NextReservEntryNo := ReservEntry."Entry No." + 1
            else
                NextReservEntryNo := 1;

            ReservEntry.Init();
            ReservEntry."Entry No." := NextReservEntryNo;
            ReservEntry."Item No." := ItemNo;
            ReservEntry."Location Code" := LocationCode;
            ReservEntry."Lot No." := LotNo;
            ReservEntry."Reservation Status" := ReservEntry."Reservation Status"::Surplus;
            ReservEntry."Source Type" := Database::"Item Journal Line";
            ReservEntry."Source Subtype" := ItemJnlLine."Entry Type".AsInteger();
            ReservEntry."Source ID" := ItemJnlLine."Journal Template Name";
            ReservEntry."Source Batch Name" := ItemJnlLine."Journal Batch Name";
            ReservEntry."Source Ref. No." := ItemJnlLine."Line No.";
            ReservEntry."Quantity (Base)" := Qty;
            ReservEntry.Quantity := Qty;
            ReservEntry.Positive := (Qty > 0);
            ReservEntry."Creation Date" := Today();
            ReservEntry."Created By" := CopyStr(UserId(), 1, MaxStrLen(ReservEntry."Created By"));
            ReservEntry.Insert();
        end;
    end;

    local procedure CreatePurchaseOrder(BlanketHeader: Record "Purchase Header"; PostingDate: Date)
    var
        PurchaseHeader: Record "Purchase Header";
        PurchaseLine: Record "Purchase Line";
        BlanketLine: Record "Purchase Line";
        NextLineNo: Integer;
    begin
        // Create new Purchase Header (Order)
        PurchaseHeader.Init();
        PurchaseHeader."Document Type" := PurchaseHeader."Document Type"::Order;
        PurchaseHeader.Validate("Buy-from Vendor No.", BlanketHeader."Buy-from Vendor No.");
        PurchaseHeader.Validate("Buy-from Vendor Name", BlanketHeader."Buy-from Vendor Name");
        PurchaseHeader.Validate("Buy-from Vendor Name 2", BlanketHeader."Buy-from Vendor Name 2");
        PurchaseHeader.Validate("Pay-to Vendor No.", BlanketHeader."Pay-to Vendor No.");
        PurchaseHeader.Validate("Pay-to Name", BlanketHeader."Pay-to Name");
        PurchaseHeader.Validate("Pay-to Name 2", BlanketHeader."Pay-to Name 2");
        PurchaseHeader.Validate("Ship-to Code", BlanketHeader."Ship-to Code");
        PurchaseHeader.Validate("Document Date", PostingDate);
        PurchaseHeader.Validate("Posting Date", PostingDate);
        PurchaseHeader.Insert(true);

        // Copy lines from blanket to order
        BlanketLine.SetRange("Document No.", BlanketHeader."No.");
        BlanketLine.SetRange("Document Type", BlanketHeader."Document Type");

        NextLineNo := 10000;
        if BlanketLine.FindSet() then
            repeat
                PurchaseLine.Init();
                PurchaseLine."Document Type" := PurchaseHeader."Document Type";
                PurchaseLine."Document No." := PurchaseHeader."No.";
                PurchaseLine."Line No." := NextLineNo;
                PurchaseLine.Type := BlanketLine.Type;
                PurchaseLine."No." := BlanketLine."No.";
                PurchaseLine.Quantity := BlanketLine.Quantity;
                PurchaseLine."Unit of Measure Code" := BlanketLine."Unit of Measure Code";
                PurchaseLine.Insert(true);
                NextLineNo += 10000;
            until BlanketLine.Next() = 0;
    end;
}
