page 50102 "Item Journal Input"
{
    PageType = StandardDialog;
    Caption = 'Create Item Journal Entries';
    ApplicationArea = All;

    layout
    {
        area(Content)
        {
            part(ItemLines; "Item Journal Input Subform")
            {
                ApplicationArea = All;
                Caption = 'Journal Lines';
            }
        }
    }

    var
        TempEntry: Record "Item Journal Batch Entry" temporary;
        NextEntryNo: Integer;

    trigger OnOpenPage()
    begin
        CurrPage.ItemLines.Page.SetRecords(TempEntry);
    end;

    trigger OnQueryClosePage(CloseAction: Action): Boolean
    var
        TempOut: Record "Item Journal Batch Entry" temporary;
    begin
        if CloseAction <> Action::OK then
            exit(true);
        CurrPage.ItemLines.Page.GetRecords(TempOut);
        if TempOut.IsEmpty() then begin
            Message('Please add at least one item journal line.');
            exit(false);
        end;
        TempOut.Reset();
        if TempOut.FindSet() then
            repeat
                if TempOut."Item No." = '' then begin
                    Message('Item No. must be filled in for all lines.');
                    exit(false);
                end;

            until TempOut.Next() = 0;
        exit(true);
    end;

    procedure AddItem(ItemNo: Code[20])
    begin
        NextEntryNo += 1;
        TempEntry.Init();
        TempEntry."Entry No." := NextEntryNo;
        TempEntry."Item No." := ItemNo;
        TempEntry.Insert();
    end;

    procedure GetEntries(var TempOut: Record "Item Journal Batch Entry" temporary)
    begin
        CurrPage.ItemLines.Page.GetRecords(TempOut);
    end;
}
